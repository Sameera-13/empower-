# ===== SERVER (.env in /server) =====

# MongoDB (leave empty to use localhost:27017/womenrise)
MONGO_URI=

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# Cloudinary (leave empty for local file storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email / SMTP (leave empty for console logging)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@womenrise.app

# Google Maps (leave empty for placeholder)
GOOGLE_MAPS_KEY=

# Razorpay (leave empty for mock payment mode)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Client URL (for CORS and email links)
CLIENT_URL=http://localhost:5173

# Admin Seed
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@womenrise.app
ADMIN_PASSWORD=Admin@123456

# Server Port
PORT=5000

# ===== CLIENT (.env in /client) =====

# VITE_API_URL=http://localhost:5000/api
# VITE_GOOGLE_MAPS_KEY=
# VITE_CLOUDINARY_CLOUD_NAME=
